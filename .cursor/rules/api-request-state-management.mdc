## Integration with TanStack Query

For list endpoints, the query hook handles loading/error states; you only
need explicit handlers around mutations.

```typescript
import { useQuery, useQueryClient } from '@tanstack/react-query';

export function TaskList() {
  const { data, isLoading, error } = useQuery({
    queryKey: ['gen-tasks', 'history', { limit: 20, offset: 0 }],
    queryFn: () => callApi<{ genTasks: GenTask[] }>('/api/gen-tasks/history?limit=20', undefined, { method: 'GET' }),
  });

  if (isLoading) return <HistorySkeleton count={8} />;
  if (error)     return <ErrorState />;
  if (!data?.data.genTasks.length) return <EmptyState />;

  return <TaskListContent tasks={data.data.genTasks} />;
}
```

For mutations, manage `isLoading` locally **or** use `useMutation` and
`mutation.isPending`; either way, error/duplicate handling stays the same.

