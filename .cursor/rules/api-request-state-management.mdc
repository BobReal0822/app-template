## Canonical Pattern: `callApi` + `ApiError`

For same-origin Next.js Route Handlers, use `callApi` from
`@/lib/api/client`. It returns the parsed `ApiResponse<T>` and throws
`ApiError` on `code !== 0` or HTTP failure. **All hooks must be called at
the component top level — never inside an event handler.**

```tsx
'use client';

import { useState } from 'react';
import { useTranslations } from 'next-intl';
import { useRouter } from 'next/navigation';
import { toast } from 'sonner';
import { Loader2, AlertCircle } from 'lucide-react';

import { Alert, AlertDescription } from '@/components/ui/alert';
import { Button } from '@/components/ui/button';
import { ApiError, callApi } from '@/lib/api/client';
import { ErrorCode, ErrorMessages } from '@/lib/api/response';

export function MyAction() {
  // ✅ Hooks at the top of the component, never in handlers
  const t = useTranslations('errors');
  const router = useRouter();

  const [isLoading, setIsLoading] = useState(false);
  const [error, setError] = useState<string | null>(null);

  const handleSubmit = async () => {
    if (isLoading) return; // dedupe
    setError(null);
    setIsLoading(true);

    try {
      const result = await callApi<{ taskId: string }>('/my-endpoint', {
        /* request body */
      });
      toast.success(t('operationCompleted'));
      router.push(`/tasks/${result.data.taskId}`);
    } catch (err) {
      if (err instanceof ApiError) {
        // ApiError is thrown for HTTP non-2xx AND for envelope `code !== 0`
        switch (err.code) {
          case ErrorCode.UNAUTHORIZED:
            router.push('/auth/login');
            break;
          case ErrorCode.INSUFFICIENT_CREDITS:
            setError(t('insufficientCredits'));
            break;
          default:
            setError(
              ErrorMessages[err.code] ?? ErrorMessages[ErrorCode.INTERNAL_SERVER_ERROR],
            );
        }
      } else {
        // TypeError / aborted / DNS / offline → network error bucket
        setError(
          ErrorMessages[ErrorCode.NETWORK_ERROR] ?? ErrorMessages[ErrorCode.INTERNAL_SERVER_ERROR],
        );
      }
      console.error('[MyAction] request failed:', err);
    } finally {
      setIsLoading(false);
    }
  };

  return (
    <div>
      {error && (
        <Alert variant="destructive">
          <AlertCircle className="h-4 w-4" />
          <AlertDescription>{error}</AlertDescription>
        </Alert>
      )}
      <Button onClick={handleSubmit} disabled={isLoading}>
        {isLoading ? <Loader2 className="mr-2 h-4 w-4 animate-spin" /> : null}
        {isLoading ? t('loading') : t('submit')}
      </Button>
    </div>
  );
}
```

> **Use `ErrorCode.*` enum members in `switch` statements, not magic
> numbers.** Magic numbers like `2001` drift over time; the enum is the
> single source of truth (`@/lib/api/response`).

