## Database Schema as Source of Truth

### Example: Projects Table

```sql
-- Database schema (PostgreSQL via Neon)
CREATE TABLE projects (
  id UUID PRIMARY KEY,
  uid TEXT NOT NULL,
  name TEXT NOT NULL,
  status TEXT NOT NULL,
  prod_id UUID,
  config JSONB,
  result_media_id UUID,
  output_key TEXT,
  thumbnail_key TEXT,
  duration INTEGER,
  cost DECIMAL,
  created_at TIMESTAMP,
  updated_at TIMESTAMP,
  deleted_at TIMESTAMP
);
```

### Drizzle schema (must match SQL)

```typescript
// packages/db/src/schema/projects.ts — columns must mirror SQL 1:1
import { pgTable, uuid, text, integer, timestamp, jsonb, numeric } from 'drizzle-orm/pg-core';

export const projects = pgTable('projects', {
  id: uuid('id').primaryKey(),
  uid: text('uid').notNull(),
  name: text('name').notNull(),
  status: text('status').notNull(),
  // …remaining fields align with the CREATE TABLE above
});
```

### Backend Response (Must Match)

```typescript
// Route Handler / server handler JSON envelope (example)
return successResponse({
  projects: [
    {
      id: 'uuid',
      uid: 'user-id',
      name: 'Project Name',
      status: 'completed',
      prodId: 'product-id',
      // ... all fields match database
    },
  ],
});
```

### Frontend Component (Must Match)

```typescript
// ✅ GOOD: Component uses same structure
interface Project {
  id: string;
  uid: string;
  name: string;
  status: string;
  prodId: string | null;
  // ... all fields match database
}

export function ProjectList({ projects }: { projects: Project[] }) {
  return <div>{/* Use projects directly */}</div>;
}
```

