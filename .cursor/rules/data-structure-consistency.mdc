## When Transformation IS Acceptable

### ✅ Acceptable: Display Formatting

```typescript
// ✅ GOOD: Format for display only
function ProjectCard({ project }: { project: Project }) {
  // Format date for display
  const displayDate = formatDate(project.createdAt);
  
  // Format status for display
  const statusLabel = getStatusLabel(project.status);
  
  return (
    <div>
      <h3>{project.name}</h3>
      <p>Created: {displayDate}</p>
      <Badge>{statusLabel}</Badge>
    </div>
  );
}
```

### ✅ Acceptable: Computed/Derived Values

```typescript
// ✅ GOOD: Add computed values without changing structure
function ProjectCard({ project }: { project: Project }) {
  // Compute derived value
  const isOverdue = project.dueDate && new Date(project.dueDate) < new Date();
  
  return (
    <div>
      <h3>{project.name}</h3>
      {isOverdue && <Alert>This project is overdue</Alert>}
    </div>
  );
}
```

### ✅ Acceptable: Filtering/Selecting Fields

```typescript
// ✅ GOOD: Select only needed fields (but keep same names)
const projectSummaries = projects.map((p) => ({
  id: p.id, // ✅ Same name
  name: p.name, // ✅ Same name
  status: p.status, // ✅ Same name
  // Excluded: createdAt, updatedAt, etc. (not needed for this view)
}));
```

