## Server Components

```tsx
// src/app/[locale]/app/(features)/projects/page.tsx
import { redirect } from 'next/navigation';
import { getTranslations } from 'next-intl/server';

import { getCurrentUser } from '@/lib/auth/server-session';

export default async function ProjectsPage() {
  const user = await getCurrentUser();
  if (!user) redirect('/auth/login');

  const t = await getTranslations('projects');

  return (
    <div>
      <h1>{t('title')}</h1>
      <p>{t('description')}</p>
    </div>
  );
}
```

For dynamic metadata:

```tsx
import type { Metadata } from 'next';
import { getTranslations } from 'next-intl/server';

export async function generateMetadata({
  params,
}: {
  params: Promise<{ locale: string }>;
}): Promise<Metadata> {
  const { locale } = await params;
  const t = await getTranslations({ locale, namespace: 'projects' });
  return { title: t('metaTitle'), description: t('metaDescription') };
}
```

---

## Client Components

```tsx
'use client';

import { useTranslations } from 'next-intl';

export function MyButton() {
  const t = useTranslations('buttons'); // ✅ at the top of the component

  return <Button>{t('save')}</Button>;
}
```

---

## Translation Keys

### Naming convention

- Group by feature/scope: `projects.title`, `auth.login.submit`,
  `errors.insufficientCredits`.
- Match the namespace argument: `useTranslations('projects')` →
  `projects.*`.
- Lower camelCase for leaf keys: `metaTitle`, not `meta_title`.
- Use plural `xxxList` / `xxxItem` patterns when grouping list copy.

### Interpolation

```jsonc
// messages/en.json
{
  "credits": {
    "remaining": "You have {count} credits left."
  }
}
```

```typescript
const t = useTranslations('credits');
t('remaining', { count: 42 });
```

### Pluralization

```jsonc
{
  "items": {
    "count": "{count, plural, =0 {No items} =1 {1 item} other {# items}}"
  }
}
```

### Rich text (links, bold, etc.)

```typescript
t.rich('terms.accept', {
  link: (chunks) => <Link href="/terms">{chunks}</Link>,
});
```

