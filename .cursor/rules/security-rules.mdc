## Violation Examples

### ❌ Wrong Examples

```typescript
// Hardcoded literal
const apiKey = 'sk_live_51N...';
const dbPassword = 'myPassword123';

// Using NEXT_PUBLIC_ for a secret (exposed to browser)
const apiKey = process.env.NEXT_PUBLIC_STRIPE_SECRET_KEY; // ❌

// Trying to access a server secret in a client component
'use client';
const apiKey = process.env.STRIPE_SECRET_KEY; // ❌ undefined in the browser
```

### ✅ Correct Examples

```typescript
// Server-only Route Handler reads `process.env` directly
export async function POST() {
  const apiKey = process.env.RESEND_API_KEY; // ✅
}

// Centralized typed accessor for repeated use
import { stripeSecretKey } from '@/server/lib/secrets';
const stripe = new Stripe(stripeSecretKey.value());

// Client-side uses NEXT_PUBLIC_* only for non-sensitive config
'use client';
const r2PublicDomain = process.env.NEXT_PUBLIC_R2_PUBLIC_DOMAIN; // ✅
```

