# Environment files - Never expose to AI
.env
.env.*
.env*.local
.env.local
.env.development
.env.production
.env.test
.env.vercel.production.local
.env.vercel.preview.local

# …but committed examples are fine for the agent to read/write
!.env.example
!.env.vercel.example

# Secrets and credentials
*.secret.*
**/.secret.*

# Private keys and certificates
*.pem
*.key
*.crt
*.p12
*.pfx

# Database credentials
*.db
*.sqlite
*.sqlite3

# Local configuration
.local
local-scripts/

# Logs (may contain sensitive info)
*.log
logs/

# Temporary files
temp/
tmp/

# Build and output directories
**/node_modules/
node_modules/
.next/
dist/
build/
coverage/
out/

# Package manager lock files
package-lock.json
yarn.lock
pnpm-lock.yaml

# System files
.DS_Store
**/.DS_Store

# Deployment files
.vercel/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Large media files (if not needed for context)
public/

# Process manager files
.pm2/
.pm3/

docs/*-zh.md
docs/*-zh-cn.md
