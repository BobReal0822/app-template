# =============================================================================
# Environment template for Vercel deployments.
#
# Conventions
# - This template is for the Vercel "Sensitive" tier on production / preview /
#   development. Copy values without `NEXT_PUBLIC_` should be marked Sensitive.
# - `NEXT_PUBLIC_*` values are bundled into the browser. NEVER put secrets
#   under that prefix (see `.cursor/rules/security-rules.mdc`).
# - For local development, copy this file to `.env.local` and fill in dev
#   values. Server code reads via `process.env` and via the typed accessors
#   in `src/server/lib/secrets.ts`.
# =============================================================================

# === GLOBAL (same value across all environments) =============================

# --- Cloudflare R2 (object storage, S3-compatible) ---------------------------
# Account ID is not sensitive — it appears in any pub-{accountId}.r2.dev URL.
NEXT_PUBLIC_R2_ACCOUNT_ID=
# Optional CDN/public domain in front of the bucket. Leave blank to serve via
# https://pub-<accountId>.r2.dev.
NEXT_PUBLIC_R2_PUBLIC_DOMAIN=

# --- R2 server-side credentials (Sensitive) ---------------------------------
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# --- Email sender (Resend) ---------------------------------------------------
RESEND_API_KEY=

# --- Internal route auth (Sensitive) ----------------------------------------
# Shared secret validated by `/api/cron/*` routes (Vercel Cron sets this in
# the `Authorization: Bearer <CRON_SECRET>` header automatically).
CRON_SECRET=
# Shared secret validated by any internal-protected handlers you add.
INTERNAL_API_SECRET=

# === PER-ENV (different value per production / preview / development) =======

# --- App URL ----------------------------------------------------------------
# Single source of truth. Used by marketing pages, auth email links, OAuth
# callback origin, and Stripe Checkout return URL.
NEXT_PUBLIC_APP_URL=

# --- Email From -------------------------------------------------------------
EMAIL_FROM=

# --- R2 bucket (account is shared, bucket is per-env) -----------------------
# Suggested:
#   production  → your-bucket-prod
#   preview     → your-bucket-staging
#   development → your-bucket-staging
R2_BUCKET_NAME=

# --- Stripe price IDs (live mode IDs ≠ test mode IDs) -----------------------
# Referenced by src/server/config/pricing.ts. Add or remove plans to match
# your product catalog.
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PRO_S_MONTHLY=
STRIPE_PRICE_PRO_S_YEARLY=
STRIPE_PRICE_PRO_M_MONTHLY=
STRIPE_PRICE_PRO_M_YEARLY=
STRIPE_PRICE_PRO_L_MONTHLY=
STRIPE_PRICE_PRO_L_YEARLY=

# --- Stripe secrets (Sensitive) ---------------------------------------------
# production → sk_live_…
# preview / development → sk_test_…
STRIPE_SECRET_KEY=
# One signing secret per webhook endpoint. Generated by Stripe Dashboard.
STRIPE_WEBHOOK_SECRET=
# Optional Stripe Billing Portal configuration ID (bpc_…).
STRIPE_PORTAL_CONFIGURATION_ID=

# --- Neon Postgres ----------------------------------------------------------
# Use a separate Neon branch per environment.
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# --- Upstash Redis ----------------------------------------------------------
# REST credentials are used by `src/server/lib/redis.ts` (idempotency,
# rate-limit, cache). `REDIS_URL` is the standard Redis connection string
# used by `ioredis` for SSE pub/sub in `src/server/realtime/sse.ts`.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_URL=

# --- Google OAuth -----------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Better Auth (Sensitive) ------------------------------------------------
# Required in all environments. Used to hash OTPs and sign registration
# tokens. Keep strong; never blank in production.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=
