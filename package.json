{
  "name": "app-template",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": "24"
  },
  "scripts": {
    "guard:db:local": "node scripts/guard-local-db.mjs",
    "dev": "pnpm run guard:db:local && next dev",
    "dev:host": "pnpm run guard:db:local && next dev --hostname 0.0.0.0",
    "ports:cleanup": "node ./scripts/kill-ports.mjs 3000 3001 8000 8001",
    "lint": "eslint src && tsc && prettier src --check",
    "lint:errors": "eslint src --quiet && tsc && prettier src --check",
    "lint:fix": "eslint src --fix && prettier src --write",
    "lint:css": "stylelint \"src/**/*.{css,scss}\"",
    "test": "pnpm run test:playwright && pnpm run test:jest",
    "test:playwright": "playwright test",
    "test:jest": "jest",
    "build": "next build",
    "start": "next start",
    "db:generate": "dotenv -e .env.local -- pnpm -F @app/db generate",
    "db:migrate": "dotenv -e .env.local -- pnpm -F @app/db migrate",
    "db:studio": "dotenv -e .env.local -- pnpm -F @app/db studio",
    "db:seed": "dotenv -e .env.local -- pnpm -F @app/db seed",
    "db:verify": "dotenv -e .env.local -- pnpm -F @app/db verify",
    "db:check": "pnpm -F @app/db check",
    "db:test": "pnpm -F @app/db test",
    "db:migrate:prod": "dotenv -e .env.vercel.production.local -- pnpm -F @app/db migrate"
  },
  "dependencies": {
    "@app/db": "workspace:*",
    "@aws-sdk/client-s3": "^3.958.0",
    "@aws-sdk/s3-request-presigner": "^3.958.0",
    "@neondatabase/serverless": "^1.1.0",
    "@next/third-parties": "^15.3.3",
    "@radix-ui/react-accordion": "1.2.2",
    "@radix-ui/react-alert-dialog": "1.1.4",
    "@radix-ui/react-aspect-ratio": "1.1.1",
    "@radix-ui/react-avatar": "1.1.2",
    "@radix-ui/react-checkbox": "1.1.3",
    "@radix-ui/react-collapsible": "1.1.2",
    "@radix-ui/react-context-menu": "2.2.4",
    "@radix-ui/react-dialog": "1.1.4",
    "@radix-ui/react-dropdown-menu": "2.1.4",
    "@radix-ui/react-hover-card": "1.1.4",
    "@radix-ui/react-label": "2.1.1",
    "@radix-ui/react-menubar": "1.1.4",
    "@radix-ui/react-navigation-menu": "1.2.3",
    "@radix-ui/react-popover": "1.1.4",
    "@radix-ui/react-progress": "1.1.1",
    "@radix-ui/react-radio-group": "1.2.2",
    "@radix-ui/react-scroll-area": "1.2.2",
    "@radix-ui/react-select": "2.1.4",
    "@radix-ui/react-separator": "1.1.1",
    "@radix-ui/react-slider": "1.2.2",
    "@radix-ui/react-slot": "1.1.1",
    "@radix-ui/react-switch": "1.1.2",
    "@radix-ui/react-tabs": "1.1.2",
    "@radix-ui/react-toast": "1.2.4",
    "@radix-ui/react-toggle": "1.1.1",
    "@radix-ui/react-toggle-group": "1.1.1",
    "@radix-ui/react-tooltip": "1.1.6",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@radix-ui/themes": "^3.2.1",
    "@tailwindcss/postcss": "^4.1.9",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.90.17",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/queue": "^0.1.6",
    "@vercel/speed-insights": "^2.0.0",
    "better-auth": "^1.6.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "copy-to-clipboard": "^3.3.3",
    "date-fns": "4.1.0",
    "dotenv": "^17.2.2",
    "drizzle-orm": "^0.45.2",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "ioredis": "^5.10.1",
    "jose": "^6.2.2",
    "js-cookie": "^3.0.5",
    "lodash": "^4.17.21",
    "lucide-react": "^0.577.0",
    "motion": "^12.31.0",
    "nanoid": "^5.1.5",
    "next": "^15.5.7",
    "next-intl": "^3.0.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-markdown": "^9.1.0",
    "react-resizable-panels": "^3.0.6",
    "resend": "^6.6.0",
    "sonner": "^2.0.7",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.9",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.20.5",
    "tw-animate-css": "1.3.3",
    "typescript": "^5.9.2",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@next/eslint-plugin-next": "^16.1.1",
    "@playwright/test": "^1.48.1",
    "@testing-library/react": "^16.0.0",
    "@types/jest": "^29.5.12",
    "@types/js-cookie": "^3.0.6",
    "@types/lodash": "^4.17.20",
    "@types/node": "^22",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.19",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.11.1",
    "eslint-config-molindo": "^8.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.4.38",
    "prettier": "^3.3.3",
    "sass": "^1.82.0",
    "stylelint": "^16.24.0",
    "stylelint-config-standard": "^39.0.0"
  },
  "prettier": "./prettier.config.cjs"
}
